---
import { dateString, SeriesGroup } from '~/utils'
import { render, type CollectionEntry } from 'astro:content'
import type { Collation } from '~/types'
import GithubIcon from '~/icons/github.svg'

interface Props {
  post: CollectionEntry<'posts' | 'articles' | 'writeups' | 'projects'>
  tags?: Collation<any>[]
  class?: string
}

const { post, tags, class: className } = Astro.props
const { remarkPluginFrontmatter } = await render(post)
const { minutesRead } = remarkPluginFrontmatter
const seriesFrontmatter = post.data.series
let series: Collation<any> | undefined
let seriesPostNumber: number | undefined
let seriesTotal: number | undefined
if (seriesFrontmatter) {
  const seriesGroup = await SeriesGroup.build()
  series = seriesGroup.match(seriesFrontmatter)
  if (!series) {
    // This should never happen if the series data is correct
    throw new Error(`Series "${seriesFrontmatter}" not found`)
  }
  seriesPostNumber = series.entries.findIndex((p: any) => p.id === post.id) + 1
  seriesTotal = series.entries.length
}
---

<div class:list={[className, 'text-foreground/80']}>
  <div class="flex flex-col gap-3">
    <div class="flex flex-col gap-4 sm:gap-2 sm:flex-wrap items-start sm:items-center sm:flex-row">
      {
        series && seriesPostNumber && seriesTotal && (
          <a
            class="shrink-0 rounded-2xl py-[3px] px-3.5 bg-foreground/1 me-2.5 hover:bg-foreground/5 transition-colors border-1 border-foreground/16 hover:border-foreground/20"
            href={series.url}
          >
            {series.title} {seriesPostNumber} / {seriesTotal}
          </a>
        )
      }
      <div class="shrink-0 pl-0.5 text-sm flex flex-wrap items-center gap-x-1">
        <span>Published {dateString(post.data.published)}</span>
        {
          post.data.author && (
            <span class="before:content-['·'] before:font-bold before:inline-block before:mx-0.5">
              {post.data.author}
            </span>
          )
        }
        {
          minutesRead && (
            <span class="before:content-['·'] before:inline-block before:mx-0.5">
              {minutesRead}
            </span>
          )
        }
      </div>
      {
        post.data.github && (
          <>
            <span class="text-foreground/80">·</span>
            <a
              href={post.data.github}
              target="_blank"
              rel="noopener noreferrer"
              class="shrink-0 inline-flex items-center gap-1.5 rounded-2xl py-1 px-3 bg-accent/1 hover:bg-accent/8 border-1 border-accent/20 text-accent/90 text-sm transition-colors"
            >
              <GithubIcon class="size-4" />
              GitHub
            </a>
          </>
        )
      }
    </div>
    {
      tags && tags.length > 0 && (
        <dl class="grid grid-cols-[auto_1fr] gap-x-3 gap-y-2 text-sm items-baseline">
          <dt class="font-medium pt-1">Tags:</dt>
          <dd class="flex flex-wrap gap-3">
            {tags.map((tag) => (
              <a
                href={tag.url}
                class="py-1 px-3 bg-accent/1 hover:bg-accent/8 border-1 border-accent/20 text-accent/90 rounded-2xl transition-colors text-sm"
              >
                {tag.title}
              </a>
            ))}
          </dd>
        </dl>
      )
    }
  </div>
</div>
