---
import type { GetStaticPaths } from 'astro'
import Layout from '~/layouts/Layout.astro'
import { SeriesGroup, TagsGroup, getAllSortedPosts, getPostSequenceContext } from '~/utils'
import { getCollection, render, type CollectionEntry } from 'astro:content'
import PostAddendum from '~/components/PostAddendum.astro'
import type { Collation } from '~/types'
import PostDetail from '~/components/PostDetail.astro'

export const getStaticPaths = (async () => {
  const posts = await getAllSortedPosts()
  return posts.map((post) => {
    // Get sequence context for the post
    const { prev, next } = getPostSequenceContext(post as any, posts as any)
    return {
      params: { slug: post.id },
      props: { post, prev, next },
    }
  })
}) satisfies GetStaticPaths

const { post, prev, next } = Astro.props
const postData = post.data
const { headings, Content: PostContent } = await render(post)
const addendum = await getCollection('addendum')
let AddendumContent
let addendumAvatarImage
if (addendum.length > 0) {
  const addendumEntry = addendum[0]
  const { Content } = await render(addendumEntry)
  AddendumContent = Content
  addendumAvatarImage = addendumEntry.data.avatarImage
}

const sortedPosts = await getAllSortedPosts()

// Determine the collection type
const collectionType = post.collection as 'posts' | 'articles' | 'writeups' | 'projects'

// Get series posts if this post is part of a series
let series: Collation<any> | undefined
let nextPostInSeries: CollectionEntry<'posts' | 'articles' | 'writeups' | 'projects'> | undefined
if (postData.series) {
  const seriesGroup = await SeriesGroup.build(sortedPosts as any)
  series = seriesGroup.match(postData.series)
  if (!series) {
    // This should not happen if series data is correct
    throw new Error(`Series "${postData.series}" not found`)
  }
  const sequenceContext = getPostSequenceContext(post as any, series.entries as any)
  nextPostInSeries = sequenceContext.next as CollectionEntry<'posts' | 'articles' | 'writeups' | 'projects'>
}

let tags: Collation<any>[] | undefined
if (postData.tags && postData.tags.length > 0) {
  const tagsGroup = await TagsGroup.build(sortedPosts as any)
  tags = tagsGroup.matchMany(postData.tags)
}
---

<Layout
  title={postData.title}
  description={postData.description}
  author={postData.author}
  tags={postData.tags}
>
  <PostDetail
    post={post}
    Content={PostContent}
    headings={headings}
    prev={prev}
    next={next}
    series={series}
    nextPostInSeries={nextPostInSeries}
    tags={tags}
    collectionType={collectionType}
  />
  {
    AddendumContent && (
      <PostAddendum avatarImage={addendumAvatarImage}>
        <AddendumContent />
      </PostAddendum>
    )
  }
</Layout>
